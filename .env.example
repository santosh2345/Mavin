# ───────────────────────────────────────────────
# MealHub — environment variables
# Copy this file to `.env.local` and fill in real values.
# Anything marked OPTIONAL can be left blank for local dev.
# ───────────────────────────────────────────────

# Frontend → backend base URL.
# Leave as /api so the bundled Next.js API routes are used.
NEXT_PUBLIC_REST_API_ENDPOINT=/api

# Public site URL (used for emails, OG tags, etc.)
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000

# ─── MongoDB ───
# Local: mongodb://127.0.0.1:27017/mealhub
# Atlas: mongodb+srv://USER:PASS@CLUSTER.mongodb.net/mealhub
MONGODB_URI=mongodb://127.0.0.1:27017/mealhub

# ─── JWT ───
# Any long random string. Used to sign auth tokens.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=30d

# ─── Stripe ───
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── Nodemailer (OTP + contact form) ───
# Use any SMTP provider (Gmail app password, Mailtrap, SendGrid SMTP, etc.).
# If left blank the server falls back to jsonTransport (logs the email
# payload to the console) so the app still works locally.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="MealHub <no-reply@mealhub.test>"

# Where /api/contact-us submissions are emailed.
CONTACT_RECIPIENT=hello@mealhub.test

# ─── OPTIONAL analytics (no-op if blank) ───
# Google Tag Manager container id (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=
# Facebook Pixel id
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
# Firebase web config — set ALL of these to enable Firebase Analytics
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
